# --- Base de datos ---
DATABASE_URL="postgresql://usuario:password@localhost:5432/agentic_scale?schema=public"

# --- Servidor ---
PORT=4000

# --- Finnhub (https://finnhub.io) ---
FINNHUB_API_KEY="tu_api_key_finnhub"
# Tickers a los que se les consulta /company-news. Separados por coma.
FINNHUB_WATCHLIST="NVDA,AAPL,TSLA,BTC-USD"
# Ventana de días hacia atrás que se pide a /company-news en cada corrida
FINNHUB_LOOKBACK_DAYS=1

# --- Quiver Quantitative (https://www.quiverquant.com) ---
QUIVER_API_KEY="tu_api_key_quiver"
QUIVER_BASE_URL="https://api.quiverquant.com/beta"

# --- Job de ingesta periódica ---
# Expresión cron estándar (node-cron). Por defecto: cada 15 minutos.
INGEST_CRON_SCHEDULE="*/15 * * * *"
# Si es "true", corre una ingesta inmediatamente al levantar el server, además del cron.
INGEST_RUN_ON_BOOT=true
